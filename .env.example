# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which LLM to use. Options: anthropic (default) | ollama
LLM_PROVIDER=anthropic

# Model override. Defaults: claude-opus-4-6 (anthropic) | llama3.2 (ollama)
# LLM_MODEL=claude-opus-4-6

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama ────────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=ollama. Start Ollama with: ollama serve
# OLLAMA_HOST=http://localhost:11434

# ── DataForSEO ────────────────────────────────────────────────────────────────
# Real Google keyword data (volume, CPC, competition, competitor rankings)
# Sign up: https://app.dataforseo.com/register  (~$0.40 per full strategy run)
DATAFORSEO_LOGIN=your_email@example.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# ── Google Search Console ─────────────────────────────────────────────────────
# Required for the content refresh workflow (refresh.py)
#
# Setup:
#   1. Go to https://console.cloud.google.com
#   2. Create a project → enable "Google Search Console API"
#   3. Create a service account → download the JSON key file
#   4. In GSC (https://search.google.com/search-console), add the service
#      account email as a property owner
#
GSC_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json
GSC_SITE_URL=https://yoursite.com
